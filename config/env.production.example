# Production Environment Variables Template
# Copy this file and fill in your production values
# NEVER commit actual production secrets to version control

# ============================================
# Frontend Environment Variables (Vercel)
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_PYTHON_API_URL=https://your-backend.railway.app
VITE_WEBSEARCH_API_URL=https://your-backend.railway.app

# ============================================
# Backend Environment Variables (Railway/Render)
# ============================================
# These should NEVER be in frontend .env files

# OpenAI API Key (REQUIRED for AI chat)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Perplexity API Key (Optional - fallback when OpenAI hits rate limits/quota)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily API Key (REQUIRED for web search - agent can browse internet)
# Get your key at https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS Configuration (REQUIRED for frontend-backend communication)
# Set to your Vercel frontend URL(s), comma-separated for multiple origins
CORS_ORIGINS=https://your-app.vercel.app

# Application Configuration
APP_VERSION=0.1.0
ENVIRONMENT=production
LOG_LEVEL=info

# Server Configuration
PORT=8000
WORKERS=4

# Audit Logging
AI_AUDIT_LOG_PATH=/app/logs/audit.jsonl

# ============================================
# Platform-Specific Variables
# ============================================

# Railway
# RAILWAY_PROJECT_ID=your-project-id
# RAILWAY_SERVICE_ID=your-service-id

# Render
# RENDER_SERVICE_ID=your-service-id

# Vercel
# VERCEL_PROJECT_ID=your-project-id
# VERCEL_ORG_ID=your-org-id
