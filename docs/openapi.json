    "/api/v1/ai/context": {
      "get": {
        "tags": ["trade-engine"],
        "summary": "Get Ai Context",
        "description": "Get comprehensive AI context for the chatbot.\n\nUse `source=dataapi` to fetch from TheEyeBetaDataAPI (live engine data),\n`source=auto` to try DataAPI first with stub fallback, or `source=supabase`\n(default) for the original stub behavior.",
        "operationId": "get_ai_context_api_v1_ai_context_get",
        "parameters": [
          {
            "name": "include_news",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true,
              "description": "Include recent news articles",
              "title": "Include News"
            },
            "description": "Include recent news articles"
          },
          {
            "name": "news_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 15,
              "description": "Maximum news articles to return",
              "title": "News Limit"
            },
            "description": "Maximum news articles to return"
          },
          {
            "name": "signals_hours",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 168,
              "default": 48,
              "description": "Hours of signal history to include",
              "title": "Signals Hours"
            },
            "description": "Hours of signal history to include"
          },
          {
            "name": "source",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "supabase",
              "description": "Data source: supabase, dataapi, or auto",
              "title": "Source"
            },
            "description": "Data source: supabase, dataapi, or auto"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AIContextResponse" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ai/signals": {
      "get": {
        "tags": ["trade-engine"],
        "summary": "Get Signals",
        "description": "Get recent trading signals.\n\nUse `source=dataapi` or `source=auto` to fetch from TheEyeBetaDataAPI.\nDefault (supabase) returns empty list (Trade Engine not deployed).",
