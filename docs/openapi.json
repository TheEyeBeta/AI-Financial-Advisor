  "components": {
    "schemas": {
      "AIContextResponse": {
        "properties": {
          "generated_at": { "type": "string", "title": "Generated At" },
          "engine_status": { "$ref": "#/components/schemas/EngineStatus" },
          "tracked_tickers": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Tracked Tickers",
            "default": []
          },
          "ticker_snapshots": {
            "items": { "$ref": "#/components/schemas/TickerSnapshot" },
            "type": "array",
            "title": "Ticker Snapshots",
            "default": []
          },
          "recent_signals": {
            "items": { "$ref": "#/components/schemas/TradingSignal" },
            "type": "array",
            "title": "Recent Signals",
            "default": []
          },
          "recent_news": {
            "items": { "$ref": "#/components/schemas/NewsItemFull" },
            "type": "array",
            "title": "Recent News",
            "default": []
          },
          "summary": { "$ref": "#/components/schemas/EngineSummaryFull" }
        },
        "type": "object",
        "required": ["generated_at", "engine_status", "summary"],
        "title": "AIContextResponse",
        "description": "Full AI context response matching frontend TradeEngineAIContext interface."
      },
      "ChatRequest": {
        "properties": {
          "messages": {
            "anyOf": [
              {
                "items": { "$ref": "#/components/schemas/Message" },
                "type": "array"
              },
              { "type": "null" }
            ],
            "title": "Messages"
          },
          "message": {
            "anyOf": [
              { "type": "string", "maxLength": 10000, "minLength": 1 },
              { "type": "null" }
            ],
            "title": "Message"
          },
          "user_id": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "title": "User Id"
          },
          "temperature": {
            "type": "number",
            "maximum": 2,
            "minimum": 0,
            "title": "Temperature",
            "default": 0.7
          },
          "max_tokens": {
            "type": "integer",
            "maximum": 16000,
            "minimum": 1,
            "title": "Max Tokens",
            "default": 2000
          },
          "experience_level": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "title": "Experience Level"
          }
        },
        "type": "object",
        "title": "ChatRequest"
      },
      "ChatTitleRequest": {
        "properties": {
          "first_message": {
            "type": "string",
            "maxLength": 10000,
            "minLength": 1,
            "title": "First Message"
          }
        },
        "type": "object",
        "required": ["first_message"],
        "title": "ChatTitleRequest"
      },
      "EngineStatus": {
        "properties": {
          "is_running": { "type": "boolean", "title": "Is Running", "default": false },
          "engine_started_at": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "title": "Engine Started At"
          },
          "last_price_tick": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "title": "Last Price Tick"
          },
          "last_news_poll": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "title": "Last News Poll"
          },
          "total_ticks_processed": {
            "type": "integer",
            "title": "Total Ticks Processed",
            "default": 0
          },
          "total_news_fetched": {
            "type": "integer",
            "title": "Total News Fetched",
            "default": 0
          },
