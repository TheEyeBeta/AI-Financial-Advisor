    "/api/news": {
      "get": {
        "tags": ["news"],
        "summary": "Get News",
        "description": "Stub endpoint for news.\n\nNote: News articles are stored in Supabase (news_articles table).\nThis endpoint returns empty results to prevent 404 errors.\nThe frontend should use Supabase directly for news.",
        "operationId": "get_news_api_news_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 30,
              "description": "Maximum number of news items to return",
              "title": "Limit"
            },
            "description": "Maximum number of news items to return"
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                { "type": "string" },
                { "type": "null" }
              ],
              "description": "Pagination cursor",
              "title": "Cursor"
            },
            "description": "Pagination cursor"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {},
                  "type": "object",
                  "title": "Response Get News Api News Get"
                }
              }
            }
