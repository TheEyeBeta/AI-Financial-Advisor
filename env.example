# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# IMPORTANT SECURITY CHANGE:
# Do NOT expose model provider keys in VITE_* variables.
# Configure OPENAI_API_KEY on the backend service only.

# The Eye Trade Engine / AI Proxy API
# URL for backend service that proxies AI/model calls and market endpoints.
VITE_PYTHON_API_URL=http://localhost:8000

# Web Search Service API (separate FastAPI backend)
# Local default if you run `backend/websearch_service` on port 8001:
VITE_WEBSEARCH_API_URL=http://localhost:8001

# Backend-only secrets (set in backend environment, NOT in frontend .env):
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Example values (replace with your actual credentials):
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_PYTHON_API_URL=http://your-trade-engine-server:8000
# VITE_WEBSEARCH_API_URL=https://your-websearch-service.example.com
