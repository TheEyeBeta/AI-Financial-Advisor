# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI API Configuration (for AI chat - recommended)
# Get your API key from: https://platform.openai.com/api-keys
# Using gpt-4o-mini model - best cost/performance (cheapest while still very capable)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Python Backend API (optional, alternative to OpenAI for AI chat and live market data)
# Only needed if you want to use a Python backend instead of OpenAI directly
VITE_PYTHON_API_URL=http://localhost:8000

# Example values (replace with your actual credentials):
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
