# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI API Configuration (for AI chat - recommended)
# Get your API key from: https://platform.openai.com/api-keys
# Using gpt-4o-mini model - best cost/performance (cheapest while still very capable)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Deepseek API Configuration (for quantitative data analysis - optional)
# Get your API key from: https://platform.deepseek.com/
# Deepseek is used for complex quantitative analysis of trading metrics
# Only numerical data is sent to Deepseek (no PII) for compliance
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# The Eye Trade Engine API
# URL for the Trade Engine backend (TheEyeBetaLocal API service)
# Provides: Real-time prices via WebSocket, indicators, charting data, signals
# WebSocket endpoint: ws://localhost:8000/ws/live
# REST endpoints: /api/v1/tickers, /api/v1/charting, /api/v1/indicators, etc.
VITE_PYTHON_API_URL=http://localhost:8000

# Web Search Service API (separate FastAPI backend)
# This is used for general web / knowledge search that is NOT quantitative
# market data. The agent may call this when it needs up-to-date, non-trading
# information (e.g. regulatory changes, definitions, general education).
# Local default if you run `backend/websearch_service` on port 8001:
VITE_WEBSEARCH_API_URL=http://localhost:8001

# Example values (replace with your actual credentials):
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_PYTHON_API_URL=http://your-trade-engine-server:8000
# VITE_WEBSEARCH_API_URL=https://your-websearch-service.example.com
