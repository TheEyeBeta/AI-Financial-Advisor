# Backend Environment Variables
# Copy this to .env and fill in your actual API keys

# Required: OpenAI API key for AI chat functionality
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Optional model overrides (cost/accuracy tuning)
# If OPENAI_MODEL is set, it is used as a single override for all endpoints.
# OPENAI_MODEL=gpt-4.5 is ignored to avoid model_not_found on stale deployments.
# Recommended defaults in code:
# - OPENAI_CHAT_MODEL=gpt-5-mini
# - OPENAI_CLASSIFIER_MODEL=gpt-5-nano
# - OPENAI_TITLE_MODEL=gpt-5-nano
# - OPENAI_QUANT_MODEL=gpt-5-mini
# OPENAI_MODEL=
# OPENAI_CHAT_MODEL=
# OPENAI_CLASSIFIER_MODEL=
# OPENAI_TITLE_MODEL=
# OPENAI_QUANT_MODEL=

# Required: Tavily API key for web search
# Get your key at https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-key-here

# Optional: Perplexity API key (fallback when OpenAI hits rate limits)
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here
