# Backend Environment Variables
# Copy this to .env and fill in your actual API keys

# Required: OpenAI API key for AI chat functionality
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Required: Tavily API key for web search
# Get your key at https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-key-here

# Optional: Perplexity API key (fallback when OpenAI hits rate limits)
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here
